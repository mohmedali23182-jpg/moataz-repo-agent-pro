# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_IDS=8185788415,8549357772
PUBLIC_URL=https://your-service.up.railway.app
TELEGRAM_WEBHOOK_SECRET=change_this_long_secret

# Admin dashboard/API
ADMIN_API_TOKEN=change_this_long_random_token

# GitHub: PAT mode. Optional if users set /token in Telegram.
GITHUB_TOKEN=
GITHUB_DEFAULT_BRANCH=main

# GitHub App mode. Optional but recommended for multi-user production.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=

# Storage/encryption
DATABASE_PATH=/app/_data/agent.db
ENCRYPTION_KEY=

# Limits
MAX_UPLOAD_MB=50
MAX_EXTRACTED_MB=200
MAX_EXTRACTED_FILES=500
WORK_DIR=/tmp/moataz_repo_agent

# Supabase optional lawful access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_ALLOWED_TABLES=profiles,posts,categories

LOG_LEVEL=INFO
