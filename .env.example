# =========================================================
# Moataz Repo Agent / Telegram Bot - Railway Environment
# =========================================================

NODE_ENV=production
LOG_LEVEL=INFO
PUBLIC_URL=https://your-service.up.railway.app

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_IDS=
TELEGRAM_WEBHOOK_SECRET=change_this_secret

# Admin API
ADMIN_API_TOKEN=change_this_long_random_token

# GitHub
GITHUB_TOKEN=
GITHUB_DEFAULT_BRANCH=main

# Optional GitHub App / OAuth future integrations
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET=

# Local SQLite Database
DATABASE_PATH=/app/_data/agent.db

# Security: generate with Python: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
ENCRYPTION_KEY=

# Limits
MAX_UPLOAD_MB=50
MAX_EXTRACTED_MB=200
MAX_EXTRACTED_FILES=500
WORK_DIR=/tmp/moataz_repo_agent

# Supabase optional
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ALLOWED_TABLES=profiles,posts,categories
DATABASE_URL=
DIRECT_URL=

# Project Normalizer
AUTO_NORMALIZE_ARCHIVES=true

# GitHub Agent / Terminal via GitHub Actions
AGENT_ALLOW_TERMINAL=true
AGENT_REQUIRE_APPROVAL=true
AGENT_MAX_COMMAND_SECONDS=1200
AGENT_ALLOWED_COMMANDS=npm,pnpm,yarn,python,pip,pytest,node,git,ls,cat,sed,grep
AGENT_DEFAULT_WORKDIR=.

# Future AI/API Integrations - optional
OPENROUTER_API_KEY=
AI_AGENT_API_URL=
AI_AGENT_API_KEY=
