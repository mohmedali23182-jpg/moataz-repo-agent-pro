# =========================================================
# Moataz Repo Agent / Telegram Bot - Railway Environment
# =========================================================

# -------------------------
# Runtime
# -------------------------
NODE_ENV=production
LOG_LEVEL=INFO
PUBLIC_URL=https://moataz-repo-agent-pro.up.railway.app

# -------------------------
# Telegram Bot
# -------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OWNER_IDS=your_id_here
TELEGRAM_WEBHOOK_SECRET=moatazahmedalzgheersaifsaleh

# -------------------------
# Admin API
# -------------------------
ADMIN_API_TOKEN=moatqzahmedalzagheersaif

# -------------------------
# GitHub
# -------------------------
GITHUB_TOKEN=
GITHUB_DEFAULT_BRANCH=main

# -------------------------
# Local SQLite Database
# -------------------------
DATABASE_PATH=/app/_data/agent.db

# -------------------------
# Security
# -------------------------
ENCRYPTION_KEY=2z4ChpQ0TYv1rIL0kzp35BEBAlWifIptNErRYx_Zz3c=

# -------------------------
# Limits
# -------------------------
MAX_UPLOAD_MB=50
MAX_EXTRACTED_MB=200
MAX_EXTRACTED_FILES=500
WORK_DIR=/tmp/moataz_repo_agent

# -------------------------
# Supabase
# -------------------------
SUPABASE_URL=https://kltqxlzwmsvxrmyqrung.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ALLOWED_TABLES=profiles,posts,categories

# -------------------------
# PostgreSQL / Supabase Database
# -------------------------
DATABASE_URL=your_database_url_here
DIRECT_URL=your_direct_url_here

# -------------------------
# Project Normalizer
# -------------------------
AUTO_NORMALIZE_ARCHIVES=true

# -------------------------
# Agent / Terminal / External API
# -------------------------
AGENT_API_TOKEN=change_this_for_external_platforms
AGENT_ALLOW_TERMINAL=true
AGENT_REQUIRE_APPROVAL=true
AGENT_MAX_COMMAND_SECONDS=1200
AGENT_ALLOWED_COMMANDS=npm,pnpm,yarn,python,pip,pytest,node,git,ls,cat,sed,grep
AGENT_DEFAULT_WORKDIR=.
AGENT_WORKFLOW_FILE=agent-command.yml

# -------------------------
# Supabase SQL admin mode - only for databases you own
# -------------------------
SUPABASE_ALLOW_SQL=false
